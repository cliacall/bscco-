# Telegram Bot (@BotFather 创建)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id
TELEGRAM_NOTIFY_CHAT_ID=your_notify_chat_id

# AI Provider: zai 或 deepseek；默认 ZAI，DeepSeek 可切换参加另一套比赛
AI_PROVIDER=zai

# Z.AI Open Platform (https://docs.z.ai/)
ZAI_API_KEY=your_zai_api_key
ZAI_BASE_URL=https://api.z.ai/api/paas/v4/
ZAI_MODEL=glm-5.1

# DeepSeek 备用 (https://platform.deepseek.com/)
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Cobo — 留空或占位符即可，Bot 自动读本机 caw 钱包 (caw wallet pair 后)
COBO_API_KEY=your_cobo_api_key
COBO_WALLET_ID=your_wallet_uuid

# BSC RPC
BSC_RPC_URL=https://bsc-dataseed.binance.org

# 钱包余额（Cobo 已配可省略，否则填你的 BSC 地址）
WALLET_ADDRESS=

# 可选配置
WEB_PORT=8888
VOLUME_THRESHOLD=1000
SCAN_INTERVAL=10
GMGN_PULL_INTERVAL=300
# GMGN skill / gmgn-cli (https://gmgn.ai/ai 申请 Key)
GMGN_API_KEY=your_gmgn_api_key
AI_AUTO_TRADE=true
AI_MAX_POSITIONS=3
